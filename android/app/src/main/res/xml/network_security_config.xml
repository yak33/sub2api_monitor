<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许明文 HTTP 流量（sub2api 后端使用 HTTP + 自定义端口） -->
    <!-- 生产环境建议配置 HTTPS 或限制具体域名 -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
